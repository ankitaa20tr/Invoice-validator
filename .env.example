# LLM provider base URL
# Groq (free tier): https://api.groq.com/openai/v1
# HF Inference:     https://api-inference.huggingface.co/v1
API_BASE_URL=https://api.groq.com/openai/v1

# Model to use (must be available on chosen provider)
MODEL_NAME=llama-3.3-70b-versatile

# API key for the chosen provider
# For Groq: get a free key at console.groq.com
# For HF:   use your HF token as the key
OPENAI_API_KEY=your_groq_or_hf_api_key_here

# Hugging Face token (needed for HF Spaces deployment)
HF_TOKEN=your_huggingface_token_here
